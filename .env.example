# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Google Gemini API key (from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# Django secret key (generate a strong random string for production)
SECRET_KEY=change-this-to-a-long-random-string

# Set to True only for local development
DEBUG=True

# Comma-separated list of allowed hosts (used when DEBUG=False)
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ──
# Leave this unset to use the local SQLite file (db.sqlite3).
# For local XAMPP MySQL (after you create the "fyp_db" database in phpMyAdmin):
#   DATABASE_URL=mysql://root:@127.0.0.1:3306/fyp_db?charset=utf8mb4
# On Render, this is set automatically when you attach a PostgreSQL database.
DATABASE_URL=
